# ── Orrery environment template ─────────────────────────────────
# Copy to .env (root) — every value is optional for local dev.
# (Named env.example without the leading dot so secret-scanning hooks stay quiet.)

# Postgres connection string (Neon/any Postgres). Leave unset to use
# the embedded PGlite database in ./.data/pglite (zero-install dev).
# DATABASE_URL=postgres://user:pass@host/db

# Override the PGlite data directory (defaults to <cwd>/.data/pglite;
# the web app resolves it to the repo root automatically).
# ORRERY_PGLITE_DIR=

# Shared secret for POST /api/v0/jobs/* connector triggers.
# Defaults to "dev" outside production; REQUIRED in production.
# JOB_SECRET=

# Launch Library 2 needs no key. Optional supporter key raises rate limits.
# LL2_API_KEY=
